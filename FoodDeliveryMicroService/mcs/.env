# Database (MongoDB local)
MONGODB_URI=mongodb://localhost:27017/food_delivery

# RabbitMQ (optional)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Service Ports
GATEWAY_PORT=3000
ORDER_SERVICE_PORT=3001
RESTAURANT_SERVICE_PORT=3002
DELIVERY_SERVICE_PORT=3003

# Service URLs (Gateway)
ORDER_SERVICE_URL=http://localhost:3001
RESTAURANT_SERVICE_URL=http://localhost:3002
DELIVERY_SERVICE_URL=http://localhost:3003

